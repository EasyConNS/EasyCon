<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:editor="using:EasyCon2.Avalonia.Core.Editor"
        x:Class="EasyCon2.Avalonia.Views.EditorWindow"
        Title="编辑器"
        Width="1000"
        Height="700"
        MinWidth="600"
        MinHeight="400"
        Icon="/Assets/favicon.ico">

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="文件">
                <MenuItem Header="保存" InputGesture="Ctrl+S" Click="SaveMenuItem_Click"/>
            </MenuItem>
        </Menu>
        <editor:ScriptEditorControl x:Name="Editor" />
    </DockPanel>
</Window>
