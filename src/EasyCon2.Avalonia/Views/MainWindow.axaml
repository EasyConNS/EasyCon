<Window xmlns="https://github.com/avaloniaui"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:vm="using:EasyCon2.Avalonia.ViewModels"
         xmlns:conv="using:EasyCon2.Avalonia.Converters"
         xmlns:behaviors="using:EasyCon2.Avalonia.Behaviors"
         xmlns:controls="using:EasyCon2.Avalonia.Controls"
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
         mc:Ignorable="d"
         d:DesignWidth="1200"
         d:DesignHeight="800"
 x:Class="EasyCon2.Avalonia.Views.MainWindow"
          x:DataType="vm:MainWindowViewModel"
          Icon="/Assets/favicon.ico"
          Title="{Binding WindowTitle}"
          Width="1200"
          Height="800"
          MinWidth="800"
          MinHeight="600"
          behaviors:FileDropBehavior.Command="{Binding DropFileCommand}">

    <Window.Resources>
        <conv:BoolToGreenBrushConverter x:Key="BoolToGreenBrush" />
        <conv:BoolToRunColorConverter x:Key="BoolToRunColor" />
    </Window.Resources>

    <Grid RowDefinitions="Auto,*">
        <!-- 顶部区域：脚本路径和打开按钮 -->
        <Border Grid.Row="0" Padding="10">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Grid.Column="0"
                          Text="{Binding CurrentScriptPath}"
                          VerticalAlignment="Center"
                          Margin="0,0,10,0"
                          TextTrimming="CharacterEllipsis"/>
                <Button Grid.Column="1"
                       Content="编辑"
                       Command="{Binding OpenEditorCommand}"
                       IsEnabled="{Binding !IsRunning}"
                       MinWidth="80"
                       Margin="0,0,5,0"
                       HorizontalContentAlignment="Center"/>
                <Button Grid.Column="2"
                       Content="打开脚本"
                       Command="{Binding OpenScriptCommand}"
                       CommandParameter="{Binding $parent[Window]}"
                       IsEnabled="{Binding !IsRunning}"
                       MinWidth="100"
                       HorizontalContentAlignment="Center"/>
            </Grid>
        </Border>

        <!-- 主内容区域 -->
        <Grid Grid.Row="1" RowDefinitions="*,Auto">
            <!-- 日志输出区和监视器区 -->
            <Grid Grid.Row="0" ColumnDefinitions="*,*,Auto">
                <!-- 日志输出区 -->
                <Grid Grid.Column="0">
                    <TextBox Text="{Binding LogOutput}"
                            IsReadOnly="True"
                            AcceptsReturn="True"
                            TextWrapping="NoWrap"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            ScrollViewer.HorizontalScrollBarVisibility="Auto"
                            FontFamily="Consolas, Microsoft YaHei"
                            FontSize="14"
                            Padding="10"
                            behaviors:AutoScrollBehavior.IsEnabled="True"
                            PointerEntered="LogBox_PointerEntered"
                            PointerExited="LogBox_PointerExited"/>
                    <!-- 工具条覆盖层 -->
                    <Border HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="10"
                            IsVisible="{Binding IsLogToolbarVisible}"
                            Background="{DynamicResource ThemeControlFillColorDefaultBrush}"
                            Padding="5"
                            PointerEntered="LogBox_PointerEntered"
                            PointerExited="LogBox_PointerExited">
                        <Button Content="清屏"
                               Command="{Binding ClearLogCommand}"
                               Padding="10,5"
                               HorizontalContentAlignment="Center"/>
                    </Border>
                </Grid>

                <!-- 监视器区 -->
                <Grid Grid.Column="1">
                    <ContentControl Content="{Binding MonitorView}" />
                </Grid>

                <!-- 右侧工具面板 -->
                <Border Grid.Column="2"
                        Width="160"
                        BorderBrush="{DynamicResource ThemeBorderFillColorDefaultBrush}"
                        BorderThickness="1,0,0,0"
                        Margin="0,150,5,5"
                        Padding="8">
                    <StackPanel Orientation="Vertical" Spacing="8">
                        <!-- 远程操作按钮 -->
                        <Button Content="远程运行"
                                Command="{Binding RemoteRunCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Padding="8,6"/>
                        <Button Content="远程停止"
                                Command="{Binding RemoteStopCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Padding="8,6"/>
                        <Button Content="编译烧录"
                                Command="{Binding CompileFlashCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Padding="8,6"/>
                        <Button Content="清除烧录"
                                Command="{Binding ClearFlashCommand}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Padding="8,6"/>

                        <!-- 固件区域 -->
                        <Border BorderBrush="{DynamicResource ThemeBorderFillColorDefaultBrush}"
                                BorderThickness="1"
                                Padding="6"
                                CornerRadius="4">
                            <StackPanel Orientation="Vertical" Spacing="6">
                                <ComboBox ItemsSource="{Binding FirmwareOptions}"
                                          SelectedItem="{Binding SelectedFirmware}"
                                          HorizontalAlignment="Stretch"/>
                                <Button Content="生成"
                                        Command="{Binding GenerateFirmwareCommand}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        Padding="8,5"/>
                            </StackPanel>
                        </Border>

                        <!-- 脚本语法说明 -->
                        <Button Content="脚本语法说明"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                Padding="8,6"
                                BorderBrush="{DynamicResource ThemeBorderFillColorDefaultBrush}"
                                BorderThickness="1"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 底部模块连接器区域 -->
            <Border Grid.Row="1"
                   Padding="10">
                <Grid ColumnDefinitions="*,*,*,*,*"
                     HorizontalAlignment="Stretch">

                    <!-- 第一个模块连接器 -->
                    <Border Grid.Column="0"
                           BorderBrush="{DynamicResource ThemeBorderFillColorDefaultBrush}"
                           BorderThickness="1"
                           Margin="5"
                           Padding="10">
                        <StackPanel Orientation="Vertical" Spacing="10">
                            <ComboBox ItemsSource="{Binding SerialPortOptions}"
                                      SelectedItem="{Binding SelectedSerialPort}"
                                      HorizontalAlignment="Stretch"
                                      behaviors:DropDownRefreshBehavior.RefreshCommand="{Binding RefreshSerialPortsCommand}"/>
                            <Grid ColumnDefinitions="*,*">
                                <Button Grid.Column="0"
                                        Content="{Binding NintendoSwitchButtonText}"
                                        Command="{Binding ConnectNintendoSwitchCommand}"
                                        IsEnabled="{Binding !IsConnectingNintendoSwitch}"
                                        Margin="0,0,5,0"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"/>
                                <Button Grid.Column="1"
                                        Content="自动连接"
                                        Command="{Binding AutoConnectNintendoSwitchCommand}"
                                        IsEnabled="{Binding !IsConnectingNintendoSwitch}"
                                        Margin="5,0,0,0"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="{Binding NintendoSwitchStatus}"
                                      HorizontalAlignment="Center"
                                      FontWeight="Bold"
                                      Foreground="{Binding IsNintendoSwitchConnected, Converter={StaticResource BoolToGreenBrush}}"/>
                        </StackPanel>
                    </Border>

                    <!-- 第二个模块连接器 -->
                    <Border Grid.Column="1"
                           BorderBrush="{DynamicResource ThemeBorderFillColorDefaultBrush}"
                           BorderThickness="1"
                           Margin="5"
                           Padding="10">
                        <StackPanel Orientation="Vertical" Spacing="10">
                            <Grid ColumnDefinitions="*,Auto">
                                <ComboBox Grid.Column="0"
                                          ItemsSource="{Binding CaptureSourceOptions}"
                                          SelectedItem="{Binding SelectedCaptureSource}"
                                          HorizontalAlignment="Stretch"
                                          behaviors:DropDownRefreshBehavior.RefreshCommand="{Binding RefreshCaptureSourcesCommand}"/>
                                <Button Grid.Column="1"
                                        Content="监视器"
                                        Command="{Binding ShowMonitorCommand}"
                                        Margin="5,0,0,0"
                                        Padding="8,4"
                                        VerticalAlignment="Center"/>
                            </Grid>
                            <Button Grid.Column="0"
                                    Content="{Binding CaptureSourceButtonText}"
                                    Command="{Binding ConnectCaptureSourceCommand}"
                                    IsEnabled="{Binding !IsConnectingCaptureSource}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"/>
                            <TextBlock Text="{Binding CaptureSourceStatus}"
                                      HorizontalAlignment="Center"
                                      FontWeight="Bold"
                                      Foreground="{Binding IsCaptureSourceConnected, Converter={StaticResource BoolToGreenBrush}}"/>
                        </StackPanel>
                    </Border>

                    <!-- 第三个模块连接器 -->
                    <Border Grid.Column="2"
                           BorderBrush="{DynamicResource ThemeBorderFillColorDefaultBrush}"
                           BorderThickness="1"
                           Margin="5"
                           Padding="10">
                        <StackPanel Orientation="Vertical" Spacing="10">
                            <ComboBox ItemsSource="{Binding ControlSourceOptions}"
                                      SelectedItem="{Binding SelectedControlSource}"
                                      HorizontalAlignment="Stretch"
                                      behaviors:DropDownRefreshBehavior.RefreshCommand="{Binding RefreshControlSourcesCommand}"/>
                            <Grid ColumnDefinitions="*,*">
                                <Button Grid.Column="0"
                                        Content="{Binding ControllerButtonText}"
                                        Command="{Binding ConnectControllerCommand}"
                                        IsEnabled="{Binding !IsConnectingController}"
                                        Margin="0,0,5,0"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"/>
                                <Button Grid.Column="1"
                                        Content="修改按键映射"
                                        Command="{Binding EditKeyMappingCommand}"
                                        CommandParameter="{Binding $parent[Window]}"
                                        IsEnabled="{Binding IsEditKeyMappingEnabled}"
                                        Margin="5,0,0,0"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="{Binding ControlSourceStatus}"
                                      HorizontalAlignment="Center"
                                      FontWeight="Bold"
                                      Foreground="{Binding IsControllerConnected, Converter={StaticResource BoolToGreenBrush}}"/>
                        </StackPanel>
                    </Border>

                    <!-- 脚本录制模块 -->
                    <Border Grid.Column="3"
                           BorderBrush="{DynamicResource ThemeBorderFillColorDefaultBrush}"
                           BorderThickness="1"
                           Margin="5"
                           Padding="10">
                        <StackPanel Orientation="Vertical" Spacing="10">
                            <TextBlock Text="脚本录制"
                                      HorizontalAlignment="Center"
                                      FontWeight="Bold"/>
                            <Button Content="录制脚本"
                                    Command="{Binding StartRecordCommand}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"/>
                            <Button Content="停止录制"
                                    Command="{Binding StopRecordCommand}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- 运行脚本按钮 -->
                    <Border Grid.Column="4"
                           Margin="5"
                           Padding="10">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Stretch" Spacing="10">
                            <TextBlock Text="{Binding RunTimeDisplay}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       FontFamily="Consolas"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            <Button Content="{Binding RunButtonText}"
                                    Command="{Binding RunScriptCommand}"
                                    FontSize="18"
                                    FontWeight="Bold"
                                    Foreground="White"
                                    Background="{Binding IsRunning, Converter={StaticResource BoolToRunColor}}"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>