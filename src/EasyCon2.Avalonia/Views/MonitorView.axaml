<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EasyCon2.Avalonia.ViewModels"
             xmlns:behaviors="using:EasyCon2.Avalonia.Behaviors"
             x:Class="EasyCon2.Avalonia.Views.MonitorView"
             x:DataType="vm:MonitorViewModel">
    <Border BorderBrush="#FF333333" BorderThickness="2">
        <Grid>
        <Image Source="{Binding CurrentFrame}"
               Stretch="Uniform"
               StretchDirection="Both"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Stretch"
               RenderOptions.BitmapInterpolationMode="HighQuality"
               behaviors:VideoFrameBehavior.FrameIndex="{Binding FrameIndex}"/>

        <!-- 加载提示 -->
        <Border Background="#80000000"
                IsVisible="{Binding IsLoading}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="20">
            <StackPanel Spacing="10">
                <TextBlock Text="正在加载视频..."
                           FontSize="16"
                           Foreground="White"
                           HorizontalAlignment="Center"/>
                <ProgressBar IsIndeterminate="True"
                             Width="200"
                             Height="4"/>
            </StackPanel>
        </Border>

        <!-- 错误提示 -->
        <Border Background="#8B0000"
                IsVisible="{Binding HasError}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="20">
            <TextBlock Text="{Binding ErrorMessage}"
                       FontSize="16"
                       Foreground="White"
                       TextWrapping="Wrap"
                       MaxWidth="400"
                       HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</Border>
</UserControl>