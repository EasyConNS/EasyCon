{
  "name": "vscode-ecs",
  "displayName": "EasyCon for VS Code",
  "description": "EasyCon伊机控vscode插件，纯AI打造",
  "version": "0.0.3",
  "publisher": "easycon",
  "icon": "images/favicon.ico",
  "repository": {
    "type": "git",
    "url": "https://github.com/EasyConNS/EasyCon"
  },
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:easycon-script"
  ],
  "main": "src/extension.js",
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "contributes": {
    "languages": [
      {
        "id": "easycon-script",
        "aliases": [
          "EasyCon Script"
        ],
        "extensions": [
          ".ecs"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "easycon-script",
        "scopeName": "source.ecs",
        "path": "./syntaxes/ecs.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "easycon.runScript",
        "title": "Run EasyCon Script",
        "icon": "$(play)",
        "category": "easycon",
        "description": "执行easycon脚本"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "easycon.runScript",
          "when": "resourceExtname == .ecs",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "easycon.runScript",
          "when": "resourceExtname == .ecs",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "easycon.runScript",
        "key": "f5",
        "when": "resourceExtname == .ecs"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "EasyCon Script",
      "properties": {
        "easycon.languageServer.path": {
          "type": "string",
          "default": "",
          "description": "Path to the ecs-lsp executable. Leave empty to use 'ezcon lsp'."
        }
      }
    }
  }
}