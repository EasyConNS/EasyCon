# Keywords
IMPORT "MATH.txt"
FOR $i TO 10 STEP 1
    PRINT $i
NEXT
BREAK
CONTINUE

WHILE $counter < $max
    $counter += 1
END

IF $counter == 100 and @capture_data > 85
    PRINT "Done"
ELIF $counter > 50
    PRINT "Half done"
ELSE
    PRINT "Working"
ENDIF

FUNC my_function
    RETURN 0
ENDFUNC

CALL my_function

$a = my_function() / 2 - _const_value

