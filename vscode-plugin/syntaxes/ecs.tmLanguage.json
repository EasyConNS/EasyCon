{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "EasyCon Script",
  "scopeName": "source.ecs",
  "fileTypes": [".ecs"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#extern_funcs" },
    { "include": "#func_refs" },
    { "include": "#keywords" },
    { "include": "#numbers" },
    { "include": "#variables" },
    { "include": "#externals" },
    { "include": "#operators" },
    { "include": "#buttons" },
    { "include": "#sticks" },
    { "include": "#directions" },
    { "include": "#builtins" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "begin": "(?i)(#)",
          "end": "$",
          "name": "comment.line.number-sign.ecs",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.comment.ecs" }
          },
          "patterns": [
            {
              "match": "(?i)\\b(TODO|FIXME|HACK|UNDONE)\\b",
              "name": "markup.bold.ecs"
            }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "begin": "\"",
          "end": "\"",
          "name": "string.quoted.double.ecs",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.ecs" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.ecs" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.ecs",
              "match": "\\\\."
            }
          ]
        },
        {
          "begin": "'",
          "end": "'",
          "name": "string.quoted.single.ecs",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.ecs" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.ecs" }
          },
          "patterns": [
            {
              "name": "constant.character.escape.ecs",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "extern_funcs": {
      "patterns": [
        {
          "begin": "(?i)\b(EXTERN)\\s+(FUNC)\\s+([a-zA-Z_\u4e00-\u9fff][a-zA-Z0-9_\u4e00-\u9fff\uFF01]*)",
          "end": "(?=$|\\n)",
          "beginCaptures": {
            "1": { "name": "keyword.other.extern.ecs" },
            "2": { "name": "storage.function.declaration.ecs" },
            "3": { "name": "entity.name.function.ecs" }
          },
          "patterns": [
            {
              "match": "(?i)\\b(INT|BOOL|STRING|PTR|DOUBLE|VOID)\\b",
              "name": "storage.type.ecs"
            },
            {
              "match": "\"[^\"]*\"",
              "name": "string.quoted.double.ecs"
            },
            {
              "match": "(?i)\\b(FROM)\\b",
              "name": "keyword.other.extern.ecs"
            },
            {
              "match": "\\$\\$?[a-zA-Z0-9_\u4e00-\u9fff][a-zA-Z0-9_\u4e00-\u9fff]*",
              "name": "variable.other.ecs"
            }
          ]
        }
      ]
    },
    "func_refs": {
      "patterns": [
        {
          "begin": "(?i)\\b(FUNC)\\b",
          "end": "(?=$|\\n)",
          "name": "storage.function.declaration.ecs",
          "beginCaptures": {
            "1": { "name": "storage.function.declaration.ecs" }
          },
          "patterns": [
            {
              "match": "\\b([a-zA-Z_\u4e00-\u9fff][a-zA-Z0-9_\u4e00-\u9fff\uFF01]*)\\s*(?=\\()",
              "captures": {
                "1": { "name": "entity.name.function.ecs" }
              }
            },
            {
              "match": "\\b([a-zA-Z_\u4e00-\u9fff][a-zA-Z0-9_\u4e00-\u9fff\uFF01]*)\\b",
              "captures": {
                "1": { "name": "entity.name.function.ecs" }
              }
            },
            {
              "match": "\\$\\$?[a-zA-Z0-9_\u4e00-\u9fff][a-zA-Z0-9_\u4e00-\u9fff]*",
              "name": "variable.other.ecs"
            },
            {
              "match": ":",
              "name": "keyword.control.ecs"
            },
            {
              "match": "(?i)\\b(INT|BOOL|STRING|PTR|DOUBLE|VOID)\\b",
              "name": "storage.type.ecs"
            }
          ]
        },
        {
          "match": "\\b(CALL)\\s+([a-zA-Z_\u4e00-\u9fff][a-zA-Z0-9_\u4e00-\u9fff\uFF01]*)",
          "captures": {
            "1": { "name": "keyword.control.ecs" },
            "2": { "name": "entity.name.function.ecs" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "match": "(?i)\\b(EXTERN|FROM)\\b",
          "name": "keyword.other.extern.ecs"
        },
        {
          "match": "(?i)\\b(ENDFUNC)\\b",
          "name": "storage.function.declaration.ecs"
        },
        {
          "match": "(?i)\\b(BREAK|CONTINUE|RETURN)\\b",
          "name": "keyword.control.flow.ecs"
        },
        {
          "match": "(?i)\\b(FOR|WHILE|END|NEXT)\\b",
          "name": "keyword.control.repeat.ecs"
        },
        {
          "match": "(?i)\\b(IF|ELIF|ELSE|ENDIF)\\b",
          "name": "keyword.control.conditional.ecs"
        },
        {
          "match": "(?i)\\b(INT|BOOL|STRING|PTR|DOUBLE|VOID)\\b",
          "name": "storage.type.ecs"
        },
        {
          "match": "(?i)\\b(IMPORT|TO|IN|STEP|TRUE|FALSE|RESET|WAIT|CALL)\\b",
          "name": "keyword.control.ecs"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "match": "(?i)\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?",
          "name": "constant.numeric.ecs"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "match": "\\$\\$?[a-zA-Z0-9_\u4e00-\u9fff][a-zA-Z0-9_\u4e00-\u9fff]*",
          "name": "variable.other.ecs"
        }
      ]
    },
    "externals": {
      "patterns": [
        {
          "match": "@[a-zA-Z_\u4e00-\u9fff][a-zA-Z0-9_\u4e00-\u9fff]*",
          "name": "variable.language.ecs"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.c-pointer.ecs",
          "match": "(?<=\\[)\\*c(?=\\])"
        },
        {
          "name": "keyword.operator.comparison.ecs",
          "match": "(\\b(and|or)\\b)|(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.arithmetic.ecs",
          "match": "(-%?|\\+%?|\\*%?|/|%)=?"
        },
        {
          "name": "keyword.operator.bitwise.ecs",
          "match": "(<<%?|>>|!|~|&|\\^|\\|)=?"
        },
        {
          "name": "keyword.operator.special.ecs",
          "match": "(==|\\+\\+|\\*\\*|->)"
        },
        {
          "name": "keyword.operator.assignment.ecs",
          "match": "="
        },
        {
          "name": "keyword.operator.question.ecs",
          "match": "\\?"
        }
      ]
    },
    "buttons": {
      "patterns": [
        {
          "name": "entity.name.tag",
          "match": "\\b(?i:LCLICK|RCLICK|CAPTURE|MINUS|HOME|PLUS|ZL|ZR|UP|DOWN|LEFT|RIGHT|L|R|A|B|X|Y)\\b"
        }
      ]
    },
    "sticks": {
      "patterns": [
        {
          "name": "storage.type",
          "match": "\\b(?i:LS|RS)\\b"
        }
      ]
    },
    "directions": {
      "patterns": [
        {
          "name": "constant.language",
          "match": "\\b(?i:DOWNLEFT|DOWNRIGHT|UPLEFT|UPRIGHT)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "comment": "Built-in functions",
          "match": "\\b(?i:RAND|TIME|PRINT|ALERT|WAIT|AMIIBO|BEEP)\\b",
          "name": "support.function.builtin.ecs"
        }
      ]
    }
  }
}
